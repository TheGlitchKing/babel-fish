{
  "name": "babel-fish",
  "displayName": "Babel Fish",
  "version": "1.0.0",
  "description": "Auto-generates a project map, vocabulary translation layer, and developer skill for any codebase. Introspects routes, models, services, features, infrastructure, and session history to give Claude instant full-stack context. Self-updates via pre-commit hook.",
  "author": {
    "name": "TheGlitchKing",
    "url": "https://github.com/TheGlitchKing"
  },
  "repository": "https://github.com/TheGlitchKing/babel-fish",
  "license": "MIT",
  "type": "claude-plugin",
  "installation": {
    "postInstall": "bash .claude/install.sh"
  },
  "skills": [
    {
      "name": "babel-fish-developer-skill",
      "path": "skills/babel-fish-developer-skill/SKILL.md"
    }
  ],
  "hooks": [
    {
      "event": "pre-commit",
      "description": "Auto-regenerates project map when source files change",
      "path": ".githooks/pre-commit"
    }
  ],
  "requirements": {
    "claudeCode": ">=1.0.0",
    "python": ">=3.8",
    "bash": true
  },
  "tags": [
    "codebase-context",
    "project-map",
    "vocabulary",
    "developer-skill",
    "introspection",
    "drift-management"
  ],
  "categories": ["developer-tools"]
}
